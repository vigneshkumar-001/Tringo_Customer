<?xml version="1.0" encoding="utf-8"?>
<!-- Close/edit icon circle: dark glass + subtle highlight -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="999dp" />
            <solid android:color="#1F1E3A" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="999dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="24dp"
                android:centerX="0.30"
                android:centerY="0.30"
                android:startColor="#33FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
