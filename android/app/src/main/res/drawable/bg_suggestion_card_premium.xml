<?xml version="1.0" encoding="utf-8"?>
<!-- Suggestion/info card like reference (glow + inner border) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="26dp" />
            <solid android:color="#00000000" />
            <stroke
                android:width="3dp"
                android:color="#332A74FF" />
        </shape>
    </item>

    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="24dp" />
            <gradient
                android:angle="0"
                android:startColor="#201B55"
                android:endColor="#16124A" />
        </shape>
    </item>

    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="24dp" />
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#1FFFFFFF" />
        </shape>
    </item>
</layer-list>

