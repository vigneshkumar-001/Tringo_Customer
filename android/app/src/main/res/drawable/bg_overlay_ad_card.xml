<?xml version="1.0" encoding="utf-8"?>
<!-- Premium neon ad card like reference -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="28dp" />
            <solid android:color="#00000000" />
            <stroke
                android:width="3dp"
                android:color="#2E5B32FF" />
        </shape>
    </item>

    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="26dp" />
            <gradient
                android:angle="90"
                android:startColor="#070A2A"
                android:centerColor="#0D0E35"
                android:endColor="#17105A" />
        </shape>
    </item>

    <item android:insetLeft="1dp" android:insetTop="1dp" android:insetRight="1dp" android:insetBottom="1dp">
        <shape>
            <corners android:radius="26dp" />
            <solid android:color="#00000000" />
            <stroke
                android:width="1dp"
                android:color="#1FFFFFFF" />
        </shape>
    </item>
</layer-list>
