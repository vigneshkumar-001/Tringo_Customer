<?xml version="1.0" encoding="utf-8"?>
<!-- Tringo post-call ad card — matches the provided nearby-business overlay design -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_overlay_ad_card">

    <!-- Top label -->
    <TextView
        android:id="@+id/adNearLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="BUSINESS FOUND NEAR YOU!"
        android:textColor="#151515"
        android:textStyle="bold"
        android:textSize="11sp"
        android:drawableStart="@drawable/ic_pin"
        android:drawablePadding="6dp"
        android:background="@drawable/bg_chip_yellow" />

    <!-- Horizontal layout: image LEFT, content RIGHT (matches reference) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="42dp"
        android:paddingBottom="14dp">

        <!-- Shop image with views badge (RECTANGLE ONLY, rounded corners) -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_image_frame_overlay_ad"
            android:padding="2dp">

            <!-- Clip container ensures the bitmap never becomes a circle -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_image_clip_rect_12"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/adImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Views badge bottom-left (inside image) -->
                <TextView
                    android:id="@+id/adOpenText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="1,416 Views"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:background="@drawable/bg_views_badge"
                    android:drawableStart="@drawable/ic_eye"
                    android:drawablePadding="6dp"
                    android:drawableTint="#39E38C"
                    android:maxWidth="92dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>

        <!-- Right-side content column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <!-- Business name + verified tick -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/adTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Business Name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:ellipsize="none" />

                <ImageView
                    android:id="@+id/trustedBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_verified_tick"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Category subtitle -->
            <TextView
                android:id="@+id/adSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cafe &amp; Restaurant"
                android:textColor="#EAF7FF"
                android:textSize="12sp"
                android:maxLines="2"
                android:singleLine="false"
                android:ellipsize="none" />

            <!-- Location pill + offer banner row -->
            <LinearLayout
                android:id="@+id/adMetaRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical"
                android:gravity="start"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/adRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="130dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="Madurai"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:background="@drawable/bg_location_pill"
                    android:visibility="gone" />

                <!-- Offer banner -->
                <LinearLayout
                    android:id="@+id/adOfferBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:background="@drawable/bg_offer_banner"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_discount_diamond"
                        android:rotation="45">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_percent"
                            android:tint="#FFFFFF"
                            android:rotation="-45" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/adOfferTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="20% DISCOUNT"
                            android:textColor="#FACC15"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/adOfferSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="on orders above ₹200/-"
                            android:textColor="#EAF7FF"
                            android:textSize="12sp"
                            android:maxLines="3"
                            android:singleLine="false"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Status text (eg. Closed today) -->
            <TextView
                android:id="@+id/adStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Closed today"
                android:textColor="#B9D9FF"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- CTA button (full width within RIGHT column, not under image) -->
            <RelativeLayout
                android:id="@+id/adViewBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:minWidth="180dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_btn_confirm_ad"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/adViewBtnText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="View Details"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/adViewBtnArrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="#FFFFFF" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
