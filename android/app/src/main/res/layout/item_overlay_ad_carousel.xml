<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal carousel version of the premium ad card (kept consistent with reference layout) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_overlay_ad_card">

    <TextView
        android:id="@+id/adNearLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="BUSINESS FOUND NEAR YOU!"
        android:textColor="#151515"
        android:textStyle="bold"
        android:textSize="11sp"
        android:drawableStart="@drawable/ic_pin"
        android:drawablePadding="6dp"
        android:background="@drawable/bg_chip_yellow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="46dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_image_frame_overlay_ad"
            android:padding="2dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_image_clip_rect_12"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/adImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/adOpenText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="1,416 Views"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:background="@drawable/bg_views_badge"
                    android:drawableStart="@drawable/ic_eye"
                    android:drawablePadding="6dp"
                    android:drawableTint="#39E38C"
                    android:maxWidth="80dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/adTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Business Name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:singleLine="false"
                    android:ellipsize="none" />

                <ImageView
                    android:id="@+id/trustedBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_verified_tick"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/adSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Cafe &amp; Restaurant"
                android:textColor="#EAF7FF"
                android:textSize="12sp"
                android:maxLines="2"
                android:singleLine="false"
                android:ellipsize="none" />

            <LinearLayout
                android:id="@+id/adMetaRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical"
                android:gravity="start"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/adRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="120dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="City"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:background="@drawable/bg_location_pill"
                    android:visibility="gone" />

            <LinearLayout
                android:id="@+id/adOfferBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@drawable/bg_offer_banner"
                android:visibility="gone">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_discount_diamond"
                        android:rotation="45">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_percent"
                            android:tint="#FFFFFF"
                            android:rotation="-45" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/adOfferTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="20% DISCOUNT"
                            android:textColor="#FACC15"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/adOfferSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="on orders above ₹200/-"
                            android:textColor="#EAF7FF"
                            android:textSize="11.5sp"
                            android:maxLines="3"
                            android:singleLine="false"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/adViewBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:minWidth="170dp"
                android:gravity="center"
                android:text="View Details"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12.5sp"
                android:background="@drawable/bg_btn_confirm_ad"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="8dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
